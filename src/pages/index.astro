---
const pageTitle = 'Hollow Sun Industries';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Hollow Sun Industries landing page." />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main class="landing-shell" aria-label={pageTitle}>
      <header class="topline" aria-label="Company metadata">
        <span>HOLLOW SUN INDUSTRIES</span>
        <span>DEVELOPMENT BUILD</span>
        <span>PRIVATE PREVIEW 2026</span>
      </header>

      <section class="hero-card" aria-labelledby="brand-title">
        <div class="system-symbols" aria-hidden="true">
          <span class="symbol symbol-orbits"></span>
          <span class="symbol symbol-solid"></span>
          <span class="symbol symbol-cross"></span>
        </div>

        <p class="airframe-copy">
          FORCE PROTECTION PLATFORM<br />BUILD HS-02.6
        </p>

        <div class="brand-lockup">
          <svg
            class="brand-mark"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 150 150"
            role="img"
            aria-label="Hollow Sun Industries icon"
          >
            <!-- SVG created with Arrow, by QuiverAI (https://quiver.ai) -->
            <path d="m94 58 3.8-6 34.3 21.6h16.4l-45.9-29.8 21.8-34.3h-99l21.8 34.4-45.8 29.7h16.4l34.5-21.6 3.5 6-30.4 19.3c9.7 9.8 26.9 22.5 49.8 22.5 18.4 0 36.3-9.2 49.2-22.5l-30.4-19.3zm-19 13.5-32.8-53.3h65.3l-32.5 53.3zm0 19.6c-11.3 0-21.8-4-34.8-12.8l20.4-12.6 0.9 1.4c-0.2 1-0.3 2.1-0.3 3.3 0 7 5.5 13.9 13.8 13.9s13.8-6.6 13.8-13.6c0-1-0.1-2.1-0.3-3.4l1-1.6 20 12.6c-8.8 6.3-20.2 12.8-34.5 12.8z" />
            <path d="m92.6 103.4-17.6 22.6-17.2-22.5c-4-1-11-3.7-19.3-8.9l36.5 45.9 36.3-46.1c-5.8 3.5-13 7.3-18.7 9z" />
          </svg>

          <div class="brand-panel">
            <p class="payload-copy">SYSTEM STATUS<br />IN DEVELOPMENT</p>

            <div class="name-row">
              <span class="unit-number">DEV</span>
              <h1 id="brand-title">HOLLOW<br />SUN<br />DEFENSE<br />COMMAND</h1>
            </div>

            <p class="spec-copy">
              BASE DEFENSE SIMULATION PLATFORM<br />
              DIGITAL TWIN + SENSOR FUSION LAYER<br />
              PERIMETER INTELLIGENCE / QRF COORDINATION<br />
              PRIVATE TECHNICAL PREVIEW
            </p>

            <p class="revision-copy">REV 02.6</p>
          </div>
        </div>

        <span class="reticle reticle-top" aria-hidden="true"></span>
        <span class="reticle reticle-left" aria-hidden="true"></span>
        <span class="reticle reticle-right" aria-hidden="true"></span>
      </section>

      <aside class="datablock" aria-label="System details">
        <p>
          HSDS<br />
          HOLLOW SUN DEFENSE STACK<br />
          SOFTWARE-DEFINED FORCE PROTECTION
        </p>

        <div class="mesh-grid">
          <p>
            HSCN<br />
            HOLLOW SUN COMMAND NETWORK<br />
            SITE-TO-SITE
          </p>
          <p>
            PERIMETER MESH<br />
            SENSOR FUSION<br />
            HS-MESH-01
          </p>
        </div>

        <p>
          HSDAS<br />
          HOLLOW SUN DISTRIBUTED AUTONOMY STACK<br />
          DEVELOPMENT BUILD
        </p>

        <p>
          HSSN<br />
          HOLLOW SUN SECURITY NETWORK
        </p>
      </aside>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: dark light;
    --page-background: #020202;
    --brand-color: #e8e8e8;
    --muted-color: rgba(232, 232, 232, 0.78);
    --hairline-color: rgba(232, 232, 232, 0.82);
    background: var(--page-background);
    color: var(--brand-color);
    font-family: "Courier New", Courier, monospace;
  }

  @media (prefers-color-scheme: light) {
    :root {
      --page-background: #f2f0ea;
      --brand-color: #050505;
      --muted-color: rgba(5, 5, 5, 0.72);
      --hairline-color: rgba(5, 5, 5, 0.76);
    }
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    min-height: 100%;
    margin: 0;
  }

  body {
    background: var(--page-background);
  }

  .landing-shell {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    padding: clamp(1.25rem, 2vw, 2rem);
    background: var(--page-background);
  }

  .topline {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    color: var(--muted-color);
    font-size: clamp(0.65rem, 0.8vw, 0.92rem);
    letter-spacing: 0.38em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .topline span:nth-child(2) {
    text-align: center;
  }

  .topline span:nth-child(3) {
    text-align: right;
  }

  .hero-card {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(43rem, calc(100vw - 3rem));
    transform: translate(-50%, -44%);
  }

  .system-symbols {
    display: flex;
    gap: clamp(0.75rem, 1.5vw, 1.2rem);
    margin-left: clamp(0rem, 1vw, 1.5rem);
    margin-bottom: clamp(0.85rem, 1.2vw, 1.15rem);
  }

  .symbol {
    position: relative;
    display: block;
    width: clamp(2.4rem, 5vw, 3.75rem);
    aspect-ratio: 1;
    border: 0.16rem solid var(--brand-color);
    border-radius: 50%;
  }

  .symbol-orbits::before,
  .symbol-orbits::after {
    position: absolute;
    inset: -0.16rem 24%;
    content: "";
    border: 0.16rem solid var(--brand-color);
    border-radius: 50%;
  }

  .symbol-solid {
    background: var(--brand-color);
  }

  .symbol-cross::before,
  .symbol-cross::after {
    position: absolute;
    top: 50%;
    left: 12%;
    width: 76%;
    height: 0.16rem;
    content: "";
    background: var(--brand-color);
    transform: rotate(45deg);
  }

  .symbol-cross::after {
    transform: rotate(-45deg);
  }

  .airframe-copy,
  .payload-copy,
  .spec-copy,
  .revision-copy,
  .datablock {
    color: var(--muted-color);
    font-size: clamp(0.78rem, 1.35vw, 1.28rem);
    font-weight: 400;
    letter-spacing: 0.16em;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .airframe-copy {
    margin: 0 0 clamp(0.5rem, 1vw, 0.9rem) clamp(0rem, 1vw, 1.5rem);
  }

  .brand-lockup {
    display: grid;
    grid-template-columns: minmax(9rem, 17rem) minmax(16rem, 1fr);
    align-items: center;
    gap: clamp(1.2rem, 2vw, 2rem);
  }

  .brand-mark {
    display: block;
    width: 100%;
    fill: currentColor;
  }

  .payload-copy {
    margin: 0 0 clamp(0.65rem, 1.2vw, 1rem);
  }

  .name-row {
    display: flex;
    align-items: center;
    gap: clamp(0.7rem, 1vw, 1rem);
  }

  .unit-number {
    display: inline-flex;
    align-items: center;
    min-height: clamp(4.2rem, 8vw, 6rem);
    padding: 0 clamp(0.55rem, 1vw, 0.9rem);
    border: 0.18rem solid var(--hairline-color);
    color: var(--brand-color);
    font-family: Arial, Helvetica, sans-serif;
    font-size: clamp(3.6rem, 8vw, 6rem);
    font-weight: 800;
    letter-spacing: -0.08em;
    line-height: 0.85;
  }

  h1 {
    margin: 0;
    color: var(--brand-color);
    font-family: Arial, Helvetica, sans-serif;
    font-size: clamp(2.4rem, 5.9vw, 5rem);
    font-weight: 300;
    letter-spacing: -0.06em;
    line-height: 0.88;
    text-transform: uppercase;
  }

  .spec-copy {
    margin: clamp(0.8rem, 1.4vw, 1.25rem) 0 0;
  }

  .revision-copy {
    margin: clamp(1rem, 1.6vw, 1.5rem) 0 0;
  }

  .reticle {
    position: absolute;
    width: clamp(2.3rem, 4vw, 3.4rem);
    aspect-ratio: 1;
    border: 0.16rem solid var(--hairline-color);
    border-radius: 50%;
  }

  .reticle::before,
  .reticle::after {
    position: absolute;
    content: "";
    background: var(--hairline-color);
  }

  .reticle::before {
    top: 50%;
    left: -35%;
    width: 170%;
    height: 0.12rem;
    transform: translateY(-50%);
  }

  .reticle::after {
    top: -35%;
    left: 50%;
    width: 0.12rem;
    height: 170%;
    transform: translateX(-50%);
  }

  .reticle-top {
    top: 9%;
    right: 1%;
  }

  .reticle-left {
    bottom: -9%;
    left: -2%;
  }

  .reticle-right {
    right: 1%;
    bottom: -8%;
  }

  .datablock {
    position: absolute;
    bottom: clamp(1.25rem, 2vw, 2rem);
    left: clamp(1.25rem, 2vw, 2rem);
    max-width: min(32rem, calc(100vw - 2.5rem));
    font-size: clamp(0.55rem, 0.8vw, 0.82rem);
    letter-spacing: 0.18em;
  }

  .datablock p {
    margin: 0 0 clamp(1.1rem, 1.9vw, 1.7rem);
  }

  .mesh-grid {
    display: grid;
    grid-template-columns: repeat(2, max-content);
    gap: clamp(1.5rem, 3vw, 3rem);
  }

  @media (max-width: 760px) {
    .landing-shell {
      display: flex;
      min-height: 100svh;
      flex-direction: column;
      gap: 2.5rem;
      overflow: visible;
    }

    .topline {
      grid-template-columns: 1fr;
      gap: 0.45rem;
    }

    .topline span,
    .topline span:nth-child(2),
    .topline span:nth-child(3) {
      text-align: left;
    }

    .hero-card {
      position: relative;
      top: auto;
      left: auto;
      width: 100%;
      margin: auto 0;
      transform: none;
    }

    .brand-lockup {
      grid-template-columns: 1fr;
      justify-items: start;
    }

    .brand-mark {
      width: min(58vw, 13rem);
    }

    .reticle-top {
      top: 3%;
      right: 4%;
    }

    .reticle-left,
    .reticle-right {
      display: none;
    }

    .datablock {
      position: relative;
      bottom: auto;
      left: auto;
      margin-top: auto;
    }
  }

  @media (max-width: 430px) {
    .name-row {
      align-items: flex-start;
      flex-direction: column;
    }

    .mesh-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }
</style>
