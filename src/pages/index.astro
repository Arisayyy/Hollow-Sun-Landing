<style>
  :root {
    color-scheme: light dark;
    --page-background: #f7f3eb;
    --brand-color: #020202;
    background: var(--page-background);
    color: var(--brand-color);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --page-background: #020202;
      --brand-color: #f7f3eb;
    }
  }

  html,
  body {
    min-height: 100%;
    margin: 0;
  }

  body {
    background: var(--page-background);
  }

  main {
    display: grid;
    min-height: 100vh;
    place-content: center;
    justify-items: center;
    gap: clamp(1.5rem, 4vw, 3rem);
    padding: 2rem;
  }

  svg {
    display: block;
    fill: currentColor;
  }

  .company-icon {
    width: clamp(6rem, 18vw, 10rem);
  }

  .company-name {
    width: min(80vw, 34rem);
  }
</style>
