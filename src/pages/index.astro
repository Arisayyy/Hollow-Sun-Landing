---
const pageTitle = 'Hollow Sun Industries';
const description =
  'Hollow Sun Industries. Securing the world\u2019s most critical infrastructure. Permanently. Private technical preview.';
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;
// Only index the production host. Preview / deploy-preview hosts stay noindex.
const isProd = Astro.url.host === 'hollowsun.ai' || Astro.url.host === 'www.hollowsun.ai';
---

<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonical} />
    {isProd ? (
      <meta name="robots" content="index, follow" />
    ) : (
      <meta name="robots" content="noindex, nofollow" />
    )}
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Hollow Sun Industries" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Hollow Sun Industries" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Hollow Sun Industries" />

    <meta name="theme-color" content="#020202" />
  </head>
  <body>
    <main class="landing-shell" aria-label={pageTitle}>
      <section class="hero-card" aria-labelledby="brand-title">
        <div class="system-symbols" aria-hidden="true">
          <span class="symbol symbol-orbits"></span>
          <span class="symbol symbol-solid"></span>
          <span class="symbol symbol-cross"></span>
        </div>

        <p class="airframe-copy">
          FORCE PROTECTION PLATFORM<br />DEVELOPMENT BUILD HS-02.6
        </p>

        <div class="brand-lockup">
          <svg
            class="brand-mark"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 150 150"
            role="img"
            aria-label="Hollow Sun Industries icon"
          >
            <!-- SVG created with Arrow, by QuiverAI (https://quiver.ai) -->
            <path d="m94 58 3.8-6 34.3 21.6h16.4l-45.9-29.8 21.8-34.3h-99l21.8 34.4-45.8 29.7h16.4l34.5-21.6 3.5 6-30.4 19.3c9.7 9.8 26.9 22.5 49.8 22.5 18.4 0 36.3-9.2 49.2-22.5l-30.4-19.3zm-19 13.5-32.8-53.3h65.3l-32.5 53.3zm0 19.6c-11.3 0-21.8-4-34.8-12.8l20.4-12.6 0.9 1.4c-0.2 1-0.3 2.1-0.3 3.3 0 7 5.5 13.9 13.8 13.9s13.8-6.6 13.8-13.6c0-1-0.1-2.1-0.3-3.4l1-1.6 20 12.6c-8.8 6.3-20.2 12.8-34.5 12.8z" />
            <path d="m92.6 103.4-17.6 22.6-17.2-22.5c-4-1-11-3.7-19.3-8.9l36.5 45.9 36.3-46.1c-5.8 3.5-13 7.3-18.7 9z" />
          </svg>

          <div class="brand-panel">
            <p class="payload-copy">SYSTEM STATUS<br />IN DEVELOPMENT</p>

            <div class="name-row">
              <h1 id="brand-title">HOLLOW SUN<br />INDUSTRIES</h1>
            </div>

            <p class="spec-copy">
              Securing the world’s most critical infrastructure. Permanently.<br />
              PRIVATE TECHNICAL PREVIEW
            </p>

            <p class="revision-copy">REV 02.6</p>
          </div>
        </div>

        <span class="reticle reticle-top" aria-hidden="true"></span>
        <span class="reticle reticle-left" aria-hidden="true"></span>
        <span class="reticle reticle-right" aria-hidden="true"></span>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: dark light;
    --page-background: #020202;
    --brand-color: #e8e8e8;
    --muted-color: rgba(232, 232, 232, 0.78);
    --hairline-color: rgba(232, 232, 232, 0.82);
    background: var(--page-background);
    color: var(--brand-color);
    font-family: "Courier New", Courier, monospace;
  }

  @media (prefers-color-scheme: light) {
    :root {
      --page-background: #f2f0ea;
      --brand-color: #050505;
      --muted-color: rgba(5, 5, 5, 0.72);
      --hairline-color: rgba(5, 5, 5, 0.76);
    }
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    min-height: 100%;
    margin: 0;
  }

  body {
    background: var(--page-background);
  }

  .landing-shell {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    padding: clamp(1.25rem, 2vw, 2rem);
    background: var(--page-background);
  }

  .hero-card {
    --symbol-size: clamp(2.4rem, 5vw, 3.75rem);
    --symbol-offset: clamp(0rem, 1vw, 1.5rem);
    --reticle-size: clamp(2.3rem, 4vw, 3.4rem);
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(43rem, calc(100vw - 3rem));
    transform: translate(-50%, -44%);
  }

  .system-symbols {
    display: flex;
    gap: clamp(0.75rem, 1.5vw, 1.2rem);
    margin-left: var(--symbol-offset);
    margin-bottom: clamp(0.85rem, 1.2vw, 1.15rem);
  }

  .symbol {
    position: relative;
    display: block;
    width: var(--symbol-size);
    aspect-ratio: 1;
    border: 0.16rem solid var(--brand-color);
    border-radius: 50%;
  }

  .symbol-orbits::before,
  .symbol-orbits::after {
    position: absolute;
    inset: -0.16rem 24%;
    content: "";
    border: 0.16rem solid var(--brand-color);
    border-radius: 50%;
  }

  .symbol-solid {
    background: var(--brand-color);
  }

  .symbol-cross::before,
  .symbol-cross::after {
    position: absolute;
    top: 50%;
    left: 12%;
    width: 76%;
    height: 0.16rem;
    content: "";
    background: var(--brand-color);
    transform: rotate(45deg);
  }

  .symbol-cross::after {
    transform: rotate(-45deg);
  }

  .airframe-copy,
  .payload-copy,
  .spec-copy,
  .revision-copy {
    color: var(--muted-color);
    font-size: clamp(0.78rem, 1.35vw, 1.28rem);
    font-weight: 400;
    letter-spacing: 0.16em;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .airframe-copy {
    margin: 0 0 clamp(0.5rem, 1vw, 0.9rem) var(--symbol-offset);
  }

  .brand-lockup {
    display: grid;
    grid-template-columns: minmax(9rem, 17rem) minmax(16rem, 1fr);
    align-items: center;
    gap: clamp(1.2rem, 2vw, 2rem);
  }

  .brand-mark {
    display: block;
    width: 100%;
    fill: currentColor;
  }

  .payload-copy {
    margin: 0 0 clamp(0.65rem, 1.2vw, 1rem);
  }

  .name-row {
    display: flex;
    align-items: center;
    gap: clamp(0.7rem, 1vw, 1rem);
  }

  .unit-number {
    display: inline-flex;
    align-items: center;
    min-height: clamp(4.2rem, 8vw, 6rem);
    padding: 0 clamp(0.55rem, 1vw, 0.9rem);
    border: 0.18rem solid var(--hairline-color);
    color: var(--brand-color);
    font-family: Arial, Helvetica, sans-serif;
    font-size: clamp(3.6rem, 8vw, 6rem);
    font-weight: 800;
    letter-spacing: -0.08em;
    line-height: 0.85;
  }

  h1 {
    margin: 0;
    color: var(--brand-color);
    font-family: Arial, Helvetica, sans-serif;
    font-size: clamp(2.05rem, 4.9vw, 4.2rem);
    font-weight: 300;
    letter-spacing: -0.06em;
    line-height: 0.88;
    text-transform: uppercase;
  }

  .spec-copy {
    margin: clamp(0.8rem, 1.4vw, 1.25rem) 0 0;
  }

  .revision-copy {
    margin: clamp(1rem, 1.6vw, 1.5rem) 0 0;
  }

  .reticle {
    position: absolute;
    width: var(--reticle-size);
    aspect-ratio: 1;
    border: 0.16rem solid var(--hairline-color);
    border-radius: 50%;
  }

  .reticle::before,
  .reticle::after {
    position: absolute;
    content: "";
    background: var(--hairline-color);
  }

  .reticle::before {
    top: 50%;
    left: -35%;
    width: 170%;
    height: 0.12rem;
    transform: translateY(-50%);
  }

  .reticle::after {
    top: -35%;
    left: 50%;
    width: 0.12rem;
    height: 170%;
    transform: translateX(-50%);
  }

  .reticle-top {
    top: calc((var(--symbol-size) - var(--reticle-size)) / 2);
    right: 1%;
  }

  .reticle-left {
    bottom: -9%;
    left: var(--symbol-offset);
  }

  .reticle-right {
    right: 1%;
    bottom: -8%;
  }

  @media (max-width: 760px) {
    .landing-shell {
      min-height: 100svh;
      overflow: hidden;
      padding: clamp(0.85rem, 3vw, 1.25rem);
    }

    .hero-card {
      position: absolute;
      top: 50%;
      left: 50%;
      width: min(38rem, calc(100vw - 1.7rem));
      transform: translate(-50%, -48%);
    }

    .brand-lockup {
      grid-template-columns: minmax(5rem, 31vw) minmax(0, 1fr);
      gap: clamp(0.65rem, 2.2vw, 1.2rem);
    }

    .brand-mark {
      width: 100%;
    }

    .airframe-copy,
    .payload-copy,
    .spec-copy,
    .revision-copy {
      font-size: clamp(0.52rem, 2vw, 0.78rem);
      letter-spacing: 0.12em;
    }

    .unit-number {
      min-height: clamp(2.45rem, 11vw, 4.2rem);
      font-size: clamp(1.85rem, 8.8vw, 3.6rem);
    }

    h1 {
      font-size: clamp(1.45rem, 6.8vw, 2.9rem);
    }

  }
</style>


