---
const pageTitle = 'Hollow Sun Industries';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Hollow Sun Industries landing page."
    />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main aria-label={pageTitle}>
      <article class="brand-card" aria-labelledby="brand-title">
        <header class="card-header">
          <svg
            class="company-icon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 150 150"
            role="img"
            aria-label="Hollow Sun Industries icon"
          >
            <!-- SVG created with Arrow, by QuiverAI (https://quiver.ai) -->
            <path d="m94 58 3.8-6 34.3 21.6h16.4l-45.9-29.8 21.8-34.3h-99l21.8 34.4-45.8 29.7h16.4l34.5-21.6 3.5 6-30.4 19.3c9.7 9.8 26.9 22.5 49.8 22.5 18.4 0 36.3-9.2 49.2-22.5l-30.4-19.3zm-19 13.5-32.8-53.3h65.3l-32.5 53.3zm0 19.6c-11.3 0-21.8-4-34.8-12.8l20.4-12.6 0.9 1.4c-0.2 1-0.3 2.1-0.3 3.3 0 7 5.5 13.9 13.8 13.9s13.8-6.6 13.8-13.6c0-1-0.1-2.1-0.3-3.4l1-1.6 20 12.6c-8.8 6.3-20.2 12.8-34.5 12.8z" />
            <path d="m92.6 103.4-17.6 22.6-17.2-22.5c-4-1-11-3.7-19.3-8.9l36.5 45.9 36.3-46.1c-5.8 3.5-13 7.3-18.7 9z" />
          </svg>

          <div class="title-block">
            <h1 id="brand-title">HOLLOW SUN INDUSTRIES</h1>
            <p>FORCE PROTECTION TECHNOLOGY</p>
            <p>EST. 2026</p>
          </div>
        </header>

        <section class="identity-grid" aria-label="Hollow Sun Industries platform details">
          <div class="module-lockup primary-module">
            <p>HSI-X1 DEFENSE TWIN</p>
            <p>LOT HS-260702-A</p>
          </div>

          <div class="module-lockup module-type">
            <p>MODULE TYPE</p>
            <p>FP-01</p>
          </div>

          <div class="module-lockup company-lockup">
            <p>[HSI]</p>
            <p>HOLLOW SUN INDUSTRIES</p>
          </div>

          <div class="module-lockup simulation-lockup">
            <p>SITE-SCALE DEFENSE SIMULATION</p>
            <p>SENSOR FUSION + PERIMETER INTELLIGENCE</p>
            <p>BASE DIGITAL TWIN / QRF COORDINATION</p>
            <p>FUNCTIONAL LOT HSI-109752</p>
          </div>

          <div class="module-lockup revision-lockup">
            <p>REV 02.6</p>
          </div>

          <div class="module-lockup stack-lockup">
            <p>HSDS</p>
            <p>HOLLOW SUN DEFENSE STACK</p>
            <p>SOFTWARE-DEFINED FORCE PROTECTION</p>
          </div>

          <div class="module-lockup network-lockup">
            <p>HSN HOLLOW SUN</p>
            <p>SECURITY NETWORK</p>
            <p>SITE-TO-SITE</p>
          </div>

          <div class="module-lockup mesh-lockup">
            <p>PERIMETER MESH</p>
            <p>SENSOR FUSION</p>
            <p>HSI-MESH-01</p>
          </div>

          <div class="module-lockup autonomy-lockup">
            <p>HSDAS</p>
            <p>HOLLOW SUN DISTRIBUTED AUTONOMY STACK</p>
            <p>EST. 2026</p>
          </div>

          <div class="module-lockup footer-lockup">
            <p>HSN</p>
            <p>HOLLOW SUN SECURITY NETWORK</p>
          </div>
        </section>
      </article>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light dark;
    --page-background: #f7f3eb;
    --card-background: #fffaf1;
    --brand-color: #020202;
    --muted-color: rgba(2, 2, 2, 0.62);
    --rule-color: rgba(2, 2, 2, 0.24);
    background: var(--page-background);
    color: var(--brand-color);
    font-family:
      "Inter", "SF Pro Display", -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --page-background: #020202;
      --card-background: #0c0c0a;
      --brand-color: #f7f3eb;
      --muted-color: rgba(247, 243, 235, 0.68);
      --rule-color: rgba(247, 243, 235, 0.28);
    }
  }

  html,
  body {
    min-height: 100%;
    margin: 0;
  }

  body {
    background: var(--page-background);
  }

  main {
    display: grid;
    min-height: 100vh;
    place-content: center;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .brand-card {
    box-sizing: border-box;
    width: min(92vw, 48rem);
    min-width: 20rem;
    padding: clamp(1rem, 2.4vw, 1.8rem);
    color: var(--brand-color);
    background: var(--card-background);
    border: 1px solid var(--brand-color);
  }

  .card-header {
    display: grid;
    grid-template-columns: clamp(4rem, 10vw, 5.75rem) 1fr;
    align-items: center;
    gap: clamp(0.9rem, 2.4vw, 1.5rem);
    padding-bottom: clamp(0.9rem, 2.4vw, 1.35rem);
    border-bottom: 1px solid var(--rule-color);
  }

  svg {
    display: block;
    fill: currentColor;
  }

  .company-icon {
    width: 100%;
  }

  .title-block {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  p {
    margin: 0;
  }

  h1 {
    font-size: clamp(1.3rem, 4vw, 3rem);
    line-height: 0.9;
  }

  .title-block p,
  .module-lockup {
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  }

  .title-block p {
    color: var(--muted-color);
    font-size: clamp(0.5rem, 1vw, 0.7rem);
    line-height: 1.35;
  }

  .identity-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr 1fr;
    gap: clamp(0.65rem, 1.5vw, 1rem);
    padding-top: clamp(0.9rem, 2.4vw, 1.35rem);
  }

  .module-lockup {
    display: grid;
    align-content: start;
    gap: 0.28rem;
    min-height: clamp(3.4rem, 7vw, 4.5rem);
    padding: clamp(0.55rem, 1.2vw, 0.8rem);
    color: var(--brand-color);
    font-size: clamp(0.48rem, 0.9vw, 0.64rem);
    line-height: 1.35;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid var(--rule-color);
  }

  .module-lockup p:first-child {
    font-weight: 700;
  }

  .primary-module,
  .simulation-lockup,
  .stack-lockup,
  .autonomy-lockup,
  .footer-lockup {
    grid-column: span 2;
  }

  .revision-lockup,
  .footer-lockup {
    align-content: center;
    text-align: center;
  }

  .company-lockup,
  .network-lockup,
  .mesh-lockup {
    min-height: clamp(4rem, 8vw, 5.25rem);
  }

  .footer-lockup {
    grid-column: 1 / -1;
  }

  @media (max-width: 42rem) {
    main {
      overflow-x: auto;
      justify-content: start;
    }

    .brand-card {
      width: 42rem;
      max-width: none;
      transform: scale(calc((100vw - 2rem) / 42rem));
      transform-origin: top left;
    }
  }
</style>
