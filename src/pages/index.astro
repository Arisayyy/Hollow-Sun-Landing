              </svg>
            </div>
            <p class="spec-copy">
              250 CAL.30 CARTRIDGES<br />
              LINKED 4 BALL M2 - 1 TR M25<br />
              FUNCTIONAL LOT HSI-109752<br /><br />
              REV 02.6
            </p>
          </div>

          <span class="reticle reticle-left" aria-hidden="true"></span>
          <span class="reticle reticle-top" aria-hidden="true"></span>
          <span class="reticle reticle-bottom" aria-hidden="true"></span>
        </div>

        <div class="plate-data" aria-hidden="true">
          <p>HSIS<br />HOLLOW SUN MISSION ARCHITECTURE<br />SOFTWARE-DEFINED AUTONOMY</p>
          <p class="data-grid">HMN HOLLOW<br />MESH NETWORK<br />PEER-TO-PEER<br /><br />SWARM MESH<br />P2P INTELLIGENCE<br />HSM-MESH-01</p>
          <p>HSDA<br />HOLLOW SUN DISTRIBUTED AUTONOMY STACK<br />EST. 2025</p>
          <p>HSN<br />HOLLOW SWARM NETWORK</p>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light dark;
    --page-background: #f3f1ea;
    --plate-ink: #050505;
    --plate-muted: rgb(5 5 5 / 72%);
    background: var(--page-background);
    color: var(--plate-ink);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --page-background: #000;
      --plate-ink: #d8d8d8;
      --plate-muted: rgb(216 216 216 / 76%);
    }
  }

  html,
  body {
    width: 100%;
    min-height: 100%;
    margin: 0;
    overflow: hidden;
  }

  body {
    background: var(--page-background);
  }

  main {
    display: grid;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    place-items: center;
    overflow: hidden;
  }

  .plate {
    position: relative;
    width: min(100vw, 177.7778dvh);
    height: min(100dvh, 56.25vw);
    color: var(--plate-ink);
    font-family: "SFMono-Regular", "Cascadia Mono", "Liberation Mono", Menlo,
      Consolas, monospace;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .plate-top {
    position: absolute;
    top: 3.8%;
    left: 2.1%;
    right: 61.5%;
    display: flex;
    justify-content: space-between;
    color: var(--plate-muted);
    font-size: clamp(0.21rem, 0.62vw, 0.8rem);
    line-height: 1;
    white-space: nowrap;
  }

  .center-mark {
    position: absolute;
    top: 34.1%;
    left: 32.2%;
    width: 35.6%;
    height: 34.2%;
  }

  .status-symbols {
    position: absolute;
    top: 0;
    left: 0.9%;
    display: flex;
    gap: 4.3%;
    width: 32%;
  }

  .symbol {
    position: relative;
    display: block;
    width: 27%;
    aspect-ratio: 1;
    border: 0.16em solid currentColor;
    border-radius: 50%;
    box-sizing: border-box;
  }

  .symbol-ring::before,
  .symbol-ring::after,
  .symbol-cross::before,
  .symbol-cross::after {
    position: absolute;
    content: "";
    background: currentColor;
  }

  .symbol-ring::before,
  .symbol-ring::after {
    top: -3%;
    bottom: -3%;
    width: 0.14em;
    left: 35%;
  }

  .symbol-ring::after {
    left: 62%;
  }

  .symbol-dot {
    background: currentColor;
  }

  .symbol-cross::before {
    top: 48%;
    left: 12%;
    width: 76%;
    height: 0.14em;
    transform: rotate(45deg);
  }

  .symbol-cross::after {
    top: 48%;
    left: 12%;
    width: 76%;
    height: 0.14em;
    transform: rotate(-45deg);
  }

  .system-copy,
  .payload,
  .spec-copy,
  .plate-data p {
    margin: 0;
    color: var(--plate-muted);
    font-size: clamp(0.28rem, 1.08vw, 1.44rem);
    line-height: 1.12;
  }

  .system-copy {
    position: absolute;
    top: 24.5%;
    left: 1.1%;
  }

  .brand-icon {
    position: absolute;
    top: 42.8%;
    left: 1.5%;
    width: 31.4%;
    fill: currentColor;
  }

  .brand-lockup {
    position: absolute;
    top: 22%;
    left: 37.7%;
    width: 43%;
  }

  .payload {
    margin-bottom: 4.2%;
  }

  .name-row {
    display: flex;
    align-items: center;
    gap: 3.2%;
  }

  .unit-number {
    display: grid;
    width: 30%;
    aspect-ratio: 1.32;
    place-items: center;
    border: 0.055em solid currentColor;
    font-size: clamp(1.2rem, 4.6vw, 6rem);
    font-weight: 700;
    line-height: 0.8;
    letter-spacing: -0.08em;
  }

  .brand-name {
    width: 55%;
    fill: currentColor;
  }

  .spec-copy {
    margin-top: 6.5%;
  }

  .plate-data {
    position: absolute;
    left: 1.9%;
    bottom: 6.5%;
    width: 25%;
  }

  .plate-data p {
    margin-top: 6.8%;
    font-size: clamp(0.18rem, 0.62vw, 0.82rem);
  }

  .data-grid {
    columns: 2;
    column-gap: 12%;
    padding-left: 22%;
  }

  .reticle {
    position: absolute;
    width: 7.1%;
    aspect-ratio: 1;
    border: 0.11em solid currentColor;
    border-radius: 50%;
    box-sizing: border-box;
  }

  .reticle::before,
  .reticle::after {
    position: absolute;
    content: "";
    background: currentColor;
  }

  .reticle::before {
    top: 48%;
    left: -38%;
    width: 176%;
    height: 0.09em;
  }

  .reticle::after {
    top: -38%;
    left: 48%;
    width: 0.09em;
    height: 176%;
  }

  .reticle-left {
    left: -1.3%;
    bottom: -10.2%;
  }

  .reticle-top {
    right: -1.8%;
    top: 4.9%;
  }

  .reticle-bottom {
    right: -1.8%;
    bottom: -10.2%;
  }

  svg {
    display: block;
  }
</style>
